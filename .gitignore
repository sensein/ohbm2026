.DS_Store
.env
.venv/
.uv-cache/
__pycache__/
*.pyc
data/
data/inputs/
data/cache/
data/outputs/
# `src/ohbm2026/data/` is committed package data (e.g. ECO vocabulary file);
# the `data/` patterns above were intended for the top-level gitignored
# artifact root, not for source-tree package data.
!src/ohbm2026/data/
!src/ohbm2026/data/**
.cache/
.matplotlib/
export/

# Local experiment and scratch outputs
.matplotlib-cache/
experiments/*
!experiments/README.md
!experiments/2026-03-30-topic-clustering-optimization/
!experiments/2026-03-30-topic-clustering-optimization/**/
!experiments/2026-03-30-topic-clustering-optimization/**/*.md
!experiments/2026-03-30-topic-clustering-optimization/.gitignore
logs/
tmp/

# Local working memory archives
archive/
memory/archive/

# Local Claude Code session state
.claude/

# Local packaging and lock artifacts
src/*.egg-info/
uv.lock
build/

# Stage 4 artifact roots (Principle II)
data/outputs/analysis/
data/cache/analysis/
data/provenance/analysis/
data/inputs/neuroscape/
bench/
