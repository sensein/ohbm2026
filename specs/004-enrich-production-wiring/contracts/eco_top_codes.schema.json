{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "eco_top_codes.schema.json",
  "title": "ECO Top-Level Vocabulary (v1)",
  "type": "object",
  "additionalProperties": false,
  "required": ["vocabulary_version", "source", "parent_term", "fetched_at", "codes"],
  "properties": {
    "vocabulary_version": { "type": "string", "const": "eco.v1" },
    "source": { "type": "string", "pattern": "^https://" },
    "parent_term": { "type": "string", "const": "ECO:0000000" },
    "fetched_at": { "type": "string", "format": "date-time" },
    "codes": {
      "type": "array",
      "minItems": 9,
      "maxItems": 9,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["eco_id", "label", "definition"],
        "properties": {
          "eco_id": { "type": "string", "pattern": "^ECO:\\d{7}$" },
          "label": { "type": "string", "minLength": 1 },
          "definition": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
