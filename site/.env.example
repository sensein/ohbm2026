# Local dev environment for the SvelteKit site.
#
# Copy this file to `.env.local` (gitignored) and fill in the URLs. Vite
# auto-loads `.env.local` from this directory, so once it exists you can run:
#
#   VITE_SITE_MODE=neuroscape pnpm dev      # → http://localhost:5173/neuroscape/
#   VITE_SITE_MODE=atlas-root pnpm dev      # → http://localhost:5173/
#   VITE_SITE_MODE=ohbm2026   pnpm dev      # → http://localhost:5173/ohbm2026/ (default)
#
# These variables mirror the GitHub Actions repo `vars.*` used by
# .github/workflows/deploy-ui.yml and pr-preview.yml — locally you set them
# here instead of in CI. The CI → local mapping is:
#
#   vars.OHBM2026_UI_DATA_PACKAGE_URL_OHBM2026          → VITE_DATA_PACKAGE_URL_OHBM2026
#   vars.OHBM2026_UI_DATA_PACKAGE_URL_NEUROSCAPE        → VITE_DATA_PACKAGE_URL_NEUROSCAPE
#   vars.OHBM2026_UI_DATA_PACKAGE_URL_ATLAS            → VITE_DATA_PACKAGE_URL_ATLAS
#   vars.OHBM2026_UI_DATA_PACKAGE_URL_NEUROSCAPE_VECTORS → VITE_DATA_PACKAGE_URL_NEUROSCAPE_VECTORS
#   vars.OHBM2026_UI_DATA_PACKAGE_URL                  → VITE_DATA_PACKAGE_URL (legacy fallback)
#
# The loader (src/lib/data_package/loader.ts) picks ONE parquet URL per build
# based on VITE_SITE_MODE: neuroscape→_NEUROSCAPE, atlas-root→_ATLAS,
# ohbm2026→_OHBM2026, each falling back to the bare VITE_DATA_PACKAGE_URL.
# So you only need to set the URL for the mode(s) you actually run.
#
# URL values can be EITHER the same remote Dropbox shared links CI uses
# (https://www.dropbox.com/...; the loader rewrites these to the CORS-friendly
# dl.dropboxusercontent.com host automatically) OR local `file://` paths to
# parquets built by `ohbmcli build-atlas-package` (see
# specs/019-neuroscape-semantic-search/quickstart.md §4).

# --- The mode the dev server builds. Read by both svelte.config.js (base path)
#     and the bundle (src/lib/site_mode.ts). Prefer VITE_SITE_MODE over plain
#     SITE_MODE so the in-bundle discriminator is correct, not just the route. ---
VITE_SITE_MODE=neuroscape

# --- Optional. Overrides the per-mode default base path
#     (ohbm2026→/ohbm2026, neuroscape→/neuroscape, atlas-root→''). Leave unset
#     for local dev unless reproducing a PR-preview path like /pr-47. ---
# BASE_PATH=

# --- Per-mode parquet URLs (set the one(s) for the mode you run). ---
VITE_DATA_PACKAGE_URL_OHBM2026=
VITE_DATA_PACKAGE_URL_NEUROSCAPE=
VITE_DATA_PACKAGE_URL_ATLAS=

# --- Optional. The NeuroScape semantic-vectors sidecar (spec 019). Without it,
#     /neuroscape/ + atlas-root run the KNN-only semantic fallback instead of
#     the full cluster-routed vectors ranker. Read by the ranker, not loader.ts. ---
VITE_DATA_PACKAGE_URL_NEUROSCAPE_VECTORS=

# --- Optional legacy single-URL fallback used when a per-mode var above is
#     unset. Keep empty unless you want one URL to serve every mode. ---
# VITE_DATA_PACKAGE_URL=
